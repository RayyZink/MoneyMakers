openapi: "3.0.3"

info:
  title: "Money 2026 API"
  description: |
    API REST de l'application Money 2026 — gestion de budget personnel multi-utilisateurs.
    Renouveau de l'application Microsoft Money (années 1990/2000).
    
    ## Authentification
    Toutes les routes (sauf /auth/login et /auth/register) nécessitent un token JWT Bearer.
    
    ## Conventions
    - Les ressources sont nommées au pluriel
    - Les dates sont au format ISO 8601 (YYYY-MM-DD)
    - Les montants sont en euros (decimal)
    - typeMouvement : D (Débit) ou C (Crédit)
    - periode : M (Mensuel), H (Hebdomadaire), A (Aléatoire), Q (Quotidien)
  version: "1.0.0"
  contact:
    name: "Équipe Arytech - IG2I Centrale Lille"

servers:
  - url: "http://localhost:3000/api/v1"
    description: "Serveur de développement local"
  - url: "https://api.money2026.fr/v1"
    description: "Serveur de production"

tags:
  - name: Authentification
    description: "Connexion, déconnexion et gestion des sessions"
  - name: Utilisateurs
    description: "Gestion des comptes utilisateurs"
  - name: Comptes
    description: "Comptes bancaires d'un utilisateur"
  - name: Mouvements
    description: "Transactions (débits et crédits) sur un compte"
  - name: Virements
    description: "Virements entre comptes (internes ou inter-utilisateurs)"
  - name: Categories
    description: "Catégories de dépenses/revenus"
  - name: SousCategories
    description: "Sous-catégories rattachées à une catégorie"
  - name: Tiers
    description: "Tiers associés aux mouvements (commerçants, personnes…)"

# ============================================================
# SÉCURITÉ GLOBALE
# ============================================================

security:
  - bearerAuth: []

# ============================================================
# PATHS
# ============================================================

paths:

  # ------------------------------------------------------------
  # AUTHENTIFICATION
  # ------------------------------------------------------------

  /auth/register:
    options:
      tags: [Authentification]
      summary: "Options CORS pour l'inscription"
      security: []
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "POST, OPTIONS"

    post:
      tags: [Authentification]
      summary: "Créer un compte utilisateur"
      security: []
      operationId: register
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UtilisateurCreation"
            example:
              nomUtilisateur: "Dupont"
              prenomUtilisateur: "Alice"
              login: "alice.dupont"
              motDePasse: "MotDePasse123!"
              ville: "Lille"
              codePostal: "59000"
      responses:
        "201":
          description: "Utilisateur créé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Utilisateur"
        "400":
          $ref: "#/components/responses/BadRequest"
        "409":
          $ref: "#/components/responses/Conflict"
        "500":
          $ref: "#/components/responses/InternalError"

  /auth/login:
    options:
      tags: [Authentification]
      summary: "Options CORS pour la connexion"
      security: []
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "POST, OPTIONS"

    post:
      tags: [Authentification]
      summary: "Se connecter et obtenir un token JWT"
      security: []
      operationId: login
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/LoginRequest"
            example:
              login: "alice.dupont"
              motDePasse: "MotDePasse123!"
      responses:
        "200":
          description: "Connexion réussie"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/LoginResponse"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "500":
          $ref: "#/components/responses/InternalError"

  /auth/logout:
    options:
      tags: [Authentification]
      summary: "Options CORS pour la déconnexion"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "POST, OPTIONS"

    post:
      tags: [Authentification]
      summary: "Se déconnecter (invalider le token)"
      operationId: logout
      responses:
        "204":
          description: "Déconnexion réussie"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "500":
          $ref: "#/components/responses/InternalError"

  # ------------------------------------------------------------
  # UTILISATEURS
  # ------------------------------------------------------------

  /utilisateurs:
    options:
      tags: [Utilisateurs]
      summary: "Options CORS pour la collection utilisateurs"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, OPTIONS"

    get:
      tags: [Utilisateurs]
      summary: "Lister tous les utilisateurs (admin uniquement)"
      operationId: getUtilisateurs
      parameters:
        - $ref: "#/components/parameters/page"
        - $ref: "#/components/parameters/limit"
      responses:
        "200":
          description: "Liste des utilisateurs"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PageUtilisateurs"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "500":
          $ref: "#/components/responses/InternalError"

  /utilisateurs/{idUtilisateur}:
    options:
      tags: [Utilisateurs]
      summary: "Options CORS pour un utilisateur"
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, PUT, DELETE, OPTIONS"

    get:
      tags: [Utilisateurs]
      summary: "Récupérer un utilisateur par son ID"
      operationId: getUtilisateurById
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "200":
          description: "Utilisateur trouvé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Utilisateur"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    put:
      tags: [Utilisateurs]
      summary: "Mettre à jour un utilisateur"
      operationId: updateUtilisateur
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UtilisateurMAJ"
            example:
              nomUtilisateur: "Dupont"
              prenomUtilisateur: "Alice"
              ville: "Paris"
              codePostal: "75001"
      responses:
        "200":
          description: "Utilisateur mis à jour"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Utilisateur"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    delete:
      tags: [Utilisateurs]
      summary: "Supprimer un utilisateur"
      operationId: deleteUtilisateur
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "204":
          description: "Utilisateur supprimé"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

  # ------------------------------------------------------------
  # COMPTES
  # ------------------------------------------------------------

  /utilisateurs/{idUtilisateur}/comptes:
    options:
      tags: [Comptes]
      summary: "Options CORS pour la collection comptes"
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, POST, OPTIONS"

    get:
      tags: [Comptes]
      summary: "Lister les comptes d'un utilisateur"
      operationId: getComptes
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "200":
          description: "Liste des comptes"
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/Compte"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    post:
      tags: [Comptes]
      summary: "Créer un compte bancaire"
      operationId: createCompte
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CompteCreation"
            example:
              descriptionCompte: "Compte courant principal"
              nomBanque: "BNP Paribas"
              montantInitial: 1500.00
      responses:
        "201":
          description: "Compte créé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Compte"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

  /comptes/{idCompte}:
    options:
      tags: [Comptes]
      summary: "Options CORS pour un compte"
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, PUT, DELETE, OPTIONS"

    get:
      tags: [Comptes]
      summary: "Récupérer un compte par son ID"
      operationId: getCompteById
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "200":
          description: "Compte trouvé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Compte"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    put:
      tags: [Comptes]
      summary: "Mettre à jour un compte"
      operationId: updateCompte
      parameters:
        - $ref: "#/components/parameters/idCompte"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CompteMAJ"
            example:
              descriptionCompte: "Compte courant BNP"
              nomBanque: "BNP Paribas"
      responses:
        "200":
          description: "Compte mis à jour"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Compte"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    delete:
      tags: [Comptes]
      summary: "Supprimer un compte"
      operationId: deleteCompte
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "204":
          description: "Compte supprimé"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

  /comptes/{idCompte}/solde:
    options:
      tags: [Comptes]
      summary: "Options CORS pour le solde"
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, OPTIONS"

    get:
      tags: [Comptes]
      summary: "Obtenir le solde historique d'un compte à une date donnée"
      operationId: getSoldeHistorique
      parameters:
        - $ref: "#/components/parameters/idCompte"
        - name: date
          in: query
          required: false
          description: "Date de calcul du solde (défaut : aujourd'hui)"
          schema:
            type: string
            format: date
            example: "2026-01-31"
      responses:
        "200":
          description: "Solde calculé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/SoldeResponse"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

  # ------------------------------------------------------------
  # MOUVEMENTS
  # ------------------------------------------------------------

  /comptes/{idCompte}/mouvements:
    options:
      tags: [Mouvements]
      summary: "Options CORS pour la collection mouvements"
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, POST, OPTIONS"

    get:
      tags: [Mouvements]
      summary: "Lister les mouvements d'un compte"
      operationId: getMouvements
      parameters:
        - $ref: "#/components/parameters/idCompte"
        - $ref: "#/components/parameters/page"
        - $ref: "#/components/parameters/limit"
        - name: dateDebut
          in: query
          required: false
          description: "Filtrer depuis cette date"
          schema:
            type: string
            format: date
            example: "2026-01-01"
        - name: dateFin
          in: query
          required: false
          description: "Filtrer jusqu'à cette date"
          schema:
            type: string
            format: date
            example: "2026-01-31"
        - name: typeMouvement
          in: query
          required: false
          description: "Filtrer par type (D=Débit, C=Crédit)"
          schema:
            type: string
            enum: [D, C]
        - name: idCategorie
          in: query
          required: false
          schema:
            type: integer
      responses:
        "200":
          description: "Liste des mouvements"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PageMouvements"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    post:
      tags: [Mouvements]
      summary: "Créer un mouvement sur un compte"
      operationId: createMouvement
      parameters:
        - $ref: "#/components/parameters/idCompte"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/MouvementCreation"
            example:
              dateMouvement: "2026-06-05"
              idTiers: 3
              idCategorie: 1
              idSousCategorie: 2
              montant: 45.90
              typeMouvement: "D"
      responses:
        "201":
          description: "Mouvement créé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Mouvement"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "422":
          $ref: "#/components/responses/UnprocessableEntity"
        "500":
          $ref: "#/components/responses/InternalError"

  /mouvements/{idMouvement}:
    options:
      tags: [Mouvements]
      summary: "Options CORS pour un mouvement"
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, PUT, DELETE, OPTIONS"

    get:
      tags: [Mouvements]
      summary: "Récupérer un mouvement par son ID"
      operationId: getMouvementById
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      responses:
        "200":
          description: "Mouvement trouvé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MouvementDetail"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

    put:
      tags: [Mouvements]
      summary: "Mettre à jour un mouvement"
      operationId: updateMouvement
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/MouvementMAJ"
      responses:
        "200":
          description: "Mouvement mis à jour"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Mouvement"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "422":
          $ref: "#/components/responses/UnprocessableEntity"
        "500":
          $ref: "#/components/responses/InternalError"

    delete:
      tags: [Mouvements]
      summary: "Supprimer un mouvement"
      operationId: deleteMouvement
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      responses:
        "204":
          description: "Mouvement supprimé"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

  # ------------------------------------------------------------
  # VIREMENTS
  # ------------------------------------------------------------

  /virements:
    options:
      tags: [Virements]
      summary: "Options CORS pour la collection virements"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, POST, OPTIONS"

    get:
      tags: [Virements]
      summary: "Lister les virements de l'utilisateur connecté"
      operationId: getVirements
      parameters:
        - $ref: "#/components/parameters/page"
        - $ref: "#/components/parameters/limit"
        - name: interUtilisateur
          in: query
          required: false
          description: "Filtrer par type (true = inter-utilisateurs uniquement)"
          schema:
            type: boolean
      responses:
        "200":
          description: "Liste des virements"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PageVirements"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "500":
          $ref: "#/components/responses/InternalError"

    post:
      tags: [Virements]
      summary: "Créer un virement (interne ou inter-utilisateurs)"
      description: |
        Appelle la procédure stockée `creerVirement` en base.
        Crée automatiquement les deux mouvements associés (débit + crédit).
        Si les deux comptes appartiennent à des utilisateurs différents,
        le flag virementInterUtilisateur est mis à 1.
      operationId: createVirement
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/VirementCreation"
            example:
              idCompteDebit: 1
              idCompteCredit: 3
              montant: 200.00
              dateVirement: "2026-06-05"
              commentaire: "Remboursement dîner"
              idCategorie: 2
              idSousCategorie: 5
      responses:
        "201":
          description: "Virement créé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Virement"
        "400":
          $ref: "#/components/responses/BadRequest"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "422":
          $ref: "#/components/responses/UnprocessableEntity"
        "500":
          $ref: "#/components/responses/InternalError"

  /virements/{idVirement}:
    options:
      tags: [Virements]
      summary: "Options CORS pour un virement"
      parameters:
        - $ref: "#/components/parameters/idVirement"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, OPTIONS"

    get:
      tags: [Virements]
      summary: "Récupérer un virement par son ID"
      operationId: getVirementById
      parameters:
        - $ref: "#/components/parameters/idVirement"
      responses:
        "200":
          description: "Virement trouvé"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Virement"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "403":
          $ref: "#/components/responses/Forbidden"
        "404":
          $ref: "#/components/responses/NotFound"
        "500":
          $ref: "#/components/responses/InternalError"

  # ------------------------------------------------------------
  # CATEGORIES
  # ------------------------------------------------------------

  /categories:
    options:
      tags: [Categories]
      summary: "Options CORS pour la collection catégories"
      responses:
        "204":
          description: "Options disponibles"
          headers:
            Allow:
              schema:
                type: string
                example: "GET, POST, OPTIONS"

    get:
      tags: [Categories]
      summary: "Lister les catégories accessibles (système + propres)"
      description: |
        Retourne les catégories système (idUtilisateur NULL)
        et les catégories créées par l'utilisateur connecté.
        Correspond à la procédure stockée `getCategories`.
      operationId: getCategories
      responses:
        "200":
          description: "Liste des catégories avec leurs sous-catégories"
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/CategorieAvecSousCategories"
        "401":
          $ref: "#/components/responses/Unauthorized"
        "500":
          $ref: "#/components/responses/InternalError"

    post:
      tags: [Categories]
      summary: "Créer une catégorie personnalisée"
      operationId: createCategorie
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CategorieCreation"
            example:
              nomCategorie: "Santé"
      responses:
        "201":
          description: "Catégorie créée"
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Categorie"
        "400":
          $ref: "#/components/responses/BadRequest"
