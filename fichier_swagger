openapi: "3.0.3"

info:
  title: "Money 2026 API"
  description: |
    API REST multi-utilisateurs de gestion de budget personnel.
    JWT Bearer requis sur toutes les routes sauf /auth/login et /auth/register.
  version: "1.0.0"
  contact:
    name: "Les Money Makers"

servers:
  - url: "http://localhost:3000/api/v1"
    description: "Développement local"

tags:
  - name: Auth
  - name: Utilisateurs
  - name: Comptes
  - name: Mouvements
  - name: Virements
  - name: Categories
  - name: SousCategories
  - name: Tiers

security:
  - bearerAuth: []

paths:

  /auth/register:
    post:
      tags: [Auth]
      summary: "Créer un compte utilisateur"
      security: []
      operationId: register
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/UtilisateurCreation" }
      responses:
        "201":
          description: "Compte créé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Utilisateur" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "409": { $ref: "#/components/responses/Conflict" }
        "500": { $ref: "#/components/responses/InternalError" }

  /auth/login:
    options:
      tags: [Auth]
      summary: "OPTIONS — illustre le mécanisme CORS preflight"
      security: []
      responses:
        "204":
          description: "Allow: POST, OPTIONS"
          headers:
            Allow:
              schema: { type: string, example: "POST, OPTIONS" }
    post:
      tags: [Auth]
      summary: "Se connecter — retourne un token JWT"
      security: []
      operationId: login
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/LoginRequest" }
      responses:
        "200":
          description: "Connexion réussie"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/LoginResponse" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "500": { $ref: "#/components/responses/InternalError" }

  /auth/logout:
    post:
      tags: [Auth]
      summary: "Se déconnecter"
      operationId: logout
      responses:
        "204": { description: "Déconnexion réussie" }
        "401": { $ref: "#/components/responses/Unauthorized" }

  /utilisateurs/{idUtilisateur}:
    get:
      tags: [Utilisateurs]
      summary: "Récupérer son profil"
      operationId: getUtilisateurById
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "200":
          description: "Profil utilisateur"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Utilisateur" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    put:
      tags: [Utilisateurs]
      summary: "Modifier son profil"
      operationId: updateUtilisateur
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/UtilisateurMAJ" }
      responses:
        "200":
          description: "Profil mis à jour"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Utilisateur" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }

  /utilisateurs/{idUtilisateur}/comptes:
    get:
      tags: [Comptes]
      summary: "Lister ses comptes"
      operationId: getComptes
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      responses:
        "200":
          description: "Liste des comptes"
          content:
            application/json:
              schema:
                type: array
                items: { $ref: "#/components/schemas/Compte" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
    post:
      tags: [Comptes]
      summary: "Créer un compte bancaire"
      operationId: createCompte
      parameters:
        - $ref: "#/components/parameters/idUtilisateur"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/CompteCreation" }
      responses:
        "201":
          description: "Compte créé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Compte" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }

  /comptes/{idCompte}:
    options:
      tags: [Comptes]
      summary: "OPTIONS — découverte des méthodes disponibles"
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "204":
          description: "Allow: GET, PUT, DELETE, OPTIONS"
          headers:
            Allow:
              schema: { type: string, example: "GET, PUT, DELETE, OPTIONS" }
    get:
      tags: [Comptes]
      summary: "Récupérer un compte"
      operationId: getCompteById
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "200":
          description: "Compte trouvé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Compte" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    put:
      tags: [Comptes]
      summary: "Modifier un compte"
      operationId: updateCompte
      parameters:
        - $ref: "#/components/parameters/idCompte"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/CompteMAJ" }
      responses:
        "200":
          description: "Compte mis à jour"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Compte" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    delete:
      tags: [Comptes]
      summary: "Supprimer un compte"
      operationId: deleteCompte
      parameters:
        - $ref: "#/components/parameters/idCompte"
      responses:
        "204": { description: "Compte supprimé" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

  /comptes/{idCompte}/solde:
    get:
      tags: [Comptes]
      summary: "Solde historique à une date donnée"
      operationId: getSoldeHistorique
      parameters:
        - $ref: "#/components/parameters/idCompte"
        - name: date
          in: query
          schema: { type: string, format: date, example: "2026-01-31" }
      responses:
        "200":
          description: "Solde calculé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/SoldeResponse" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

  /comptes/{idCompte}/mouvements:
    get:
      tags: [Mouvements]
      summary: "Lister les mouvements d'un compte"
      operationId: getMouvements
      parameters:
        - $ref: "#/components/parameters/idCompte"
        - $ref: "#/components/parameters/page"
        - $ref: "#/components/parameters/limit"
        - name: dateDebut
          in: query
          schema: { type: string, format: date }
        - name: dateFin
          in: query
          schema: { type: string, format: date }
        - name: typeMouvement
          in: query
          schema: { type: string, enum: [D, C] }
      responses:
        "200":
          description: "Liste paginée des mouvements"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/PageMouvements" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    post:
      tags: [Mouvements]
      summary: "Créer un mouvement"
      operationId: createMouvement
      parameters:
        - $ref: "#/components/parameters/idCompte"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/MouvementCreation" }
      responses:
        "201":
          description: "Mouvement créé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Mouvement" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "422": { $ref: "#/components/responses/UnprocessableEntity" }

  /mouvements/{idMouvement}:
    options:
      tags: [Mouvements]
      summary: "OPTIONS — exemple sur une ressource document"
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      responses:
        "204":
          description: "Allow: GET, PUT, DELETE, OPTIONS"
          headers:
            Allow:
              schema: { type: string, example: "GET, PUT, DELETE, OPTIONS" }
    get:
      tags: [Mouvements]
      summary: "Récupérer un mouvement (vue V_MOUVEMENT)"
      operationId: getMouvementById
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      responses:
        "200":
          description: "Mouvement enrichi"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/MouvementDetail" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    put:
      tags: [Mouvements]
      summary: "Modifier un mouvement"
      operationId: updateMouvement
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/MouvementCreation" }
      responses:
        "200":
          description: "Mouvement mis à jour"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Mouvement" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "422": { $ref: "#/components/responses/UnprocessableEntity" }
    delete:
      tags: [Mouvements]
      summary: "Supprimer un mouvement"
      operationId: deleteMouvement
      parameters:
        - $ref: "#/components/parameters/idMouvement"
      responses:
        "204": { description: "Mouvement supprimé" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

  /virements:
    post:
      tags: [Virements]
      summary: "Créer un virement"
      description: |
        Appelle la procédure stockée creerVirement.
        Génère automatiquement 2 mouvements (débit + crédit).
        Si comptes de 2 utilisateurs différents → virementInterUtilisateur = true.
      operationId: createVirement
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/VirementCreation" }
      responses:
        "201":
          description: "Virement créé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Virement" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "422": { $ref: "#/components/responses/UnprocessableEntity" }

  /virements/{idVirement}:
    get:
      tags: [Virements]
      summary: "Récupérer un virement"
      operationId: getVirementById
      parameters:
        - name: idVirement
          in: path
          required: true
          schema: { type: integer }
      responses:
        "200":
          description: "Virement trouvé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Virement" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

  /categories:
    get:
      tags: [Categories]
      summary: "Lister les catégories (système + personnelles)"
      operationId: getCategories
      responses:
        "200":
          description: "Liste des catégories avec sous-catégories"
          content:
            application/json:
              schema:
                type: array
                items: { $ref: "#/components/schemas/CategorieAvecSousCategories" }
        "401": { $ref: "#/components/responses/Unauthorized" }
    post:
      tags: [Categories]
      summary: "Créer une catégorie"
      operationId: createCategorie
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/CategorieCreation" }
      responses:
        "201":
          description: "Catégorie créée"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Categorie" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "409": { $ref: "#/components/responses/Conflict" }

  /categories/{idCategorie}:
    get:
      tags: [Categories]
      summary: "Récupérer une catégorie"
      operationId: getCategorieById
      parameters:
        - $ref: "#/components/parameters/idCategorie"
      responses:
        "200":
          description: "Catégorie trouvée"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/CategorieAvecSousCategories" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    put:
      tags: [Categories]
      summary: "Modifier une catégorie"
      operationId: updateCategorie
      parameters:
        - $ref: "#/components/parameters/idCategorie"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/CategorieCreation" }
      responses:
        "200":
          description: "Catégorie mise à jour"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Categorie" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    delete:
      tags: [Categories]
      summary: "Supprimer une catégorie"
      operationId: deleteCategorie
      parameters:
        - $ref: "#/components/parameters/idCategorie"
      responses:
        "204": { description: "Catégorie supprimée" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

  /categories/{idCategorie}/sous-categories:
    get:
      tags: [SousCategories]
      summary: "Lister les sous-catégories"
      operationId: getSousCategories
      parameters:
        - $ref: "#/components/parameters/idCategorie"
      responses:
        "200":
          description: "Liste des sous-catégories"
          content:
            application/json:
              schema:
                type: array
                items: { $ref: "#/components/schemas/SousCategorie" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "404": { $ref: "#/components/responses/NotFound" }
    post:
      tags: [SousCategories]
      summary: "Créer une sous-catégorie"
      operationId: createSousCategorie
      parameters:
        - $ref: "#/components/parameters/idCategorie"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/SousCategorieCreation" }
      responses:
        "201":
          description: "Sous-catégorie créée"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/SousCategorie" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "404": { $ref: "#/components/responses/NotFound" }

  /sous-categories/{idSousCategorie}:
    get:
      tags: [SousCategories]
      summary: "Récupérer une sous-catégorie"
      operationId: getSousCategorieById
      parameters:
        - $ref: "#/components/parameters/idSousCategorie"
      responses:
        "200":
          description: "Sous-catégorie trouvée"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/SousCategorie" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    put:
      tags: [SousCategories]
      summary: "Modifier une sous-catégorie"
      operationId: updateSousCategorie
      parameters:
        - $ref: "#/components/parameters/idSousCategorie"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/SousCategorieCreation" }
      responses:
        "200":
          description: "Sous-catégorie mise à jour"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/SousCategorie" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "404": { $ref: "#/components/responses/NotFound" }
    delete:
      tags: [SousCategories]
      summary: "Supprimer une sous-catégorie"
      operationId: deleteSousCategorie
      parameters:
        - $ref: "#/components/parameters/idSousCategorie"
      responses:
        "204": { description: "Sous-catégorie supprimée" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

  /tiers:
    get:
      tags: [Tiers]
      summary: "Lister ses tiers"
      operationId: getTiers
      parameters:
        - $ref: "#/components/parameters/page"
        - $ref: "#/components/parameters/limit"
        - name: search
          in: query
          schema: { type: string, example: "Carrefour" }
      responses:
        "200":
          description: "Liste des tiers"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/PageTiers" }
        "401": { $ref: "#/components/responses/Unauthorized" }
    post:
      tags: [Tiers]
      summary: "Créer un tiers"
      operationId: createTiers
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/TiersCreation" }
      responses:
        "201":
          description: "Tiers créé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Tiers" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }

  /tiers/{idTiers}:
    get:
      tags: [Tiers]
      summary: "Récupérer un tiers"
      operationId: getTiersById
      parameters:
        - $ref: "#/components/parameters/idTiers"
      responses:
        "200":
          description: "Tiers trouvé"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Tiers" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }
    put:
      tags: [Tiers]
      summary: "Modifier un tiers"
      operationId: updateTiers
      parameters:
        - $ref: "#/components/parameters/idTiers"
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: "#/components/schemas/TiersCreation" }
      responses:
        "200":
          description: "Tiers mis à jour"
          content:
            application/json:
              schema: { $ref: "#/components/schemas/Tiers" }
        "400": { $ref: "#/components/responses/BadRequest" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "404": { $ref: "#/components/responses/NotFound" }
    delete:
      tags: [Tiers]
      summary: "Supprimer un tiers"
      operationId: deleteTiers
      parameters:
        - $ref: "#/components/parameters/idTiers"
      responses:
        "204": { description: "Tiers supprimé" }
        "401": { $ref: "#/components/responses/Unauthorized" }
        "403": { $ref: "#/components/responses/Forbidden" }
        "404": { $ref: "#/components/responses/NotFound" }

components:

  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: "Token JWT obtenu via POST /auth/login"

  parameters:
    idUtilisateur:
      name: idUtilisateur
      in: path
      required: true
      schema: { type: integer, example: 1 }
    idCompte:
      name: idCompte
      in: path
      required: true
      schema: { type: integer, example: 1 }
    idMouvement:
      name: idMouvement
      in: path
      required: true
      schema: { type: integer, example: 1 }
    idCategorie:
      name: idCategorie
      in: path
      required: true
      schema: { type: integer, example: 1 }
    idSousCategorie:
      name: idSousCategorie
      in: path
      required: true
      schema: { type: integer, example: 1 }
    idTiers:
      name: idTiers
      in: path
      required: true
      schema: { type: integer, example: 1 }
    page:
      name: page
      in: query
      schema: { type: integer, minimum: 1, default: 1 }
    limit:
      name: limit
      in: query
      schema: { type: integer, minimum: 1, maximum: 100, default: 20 }

  schemas:

    Utilisateur:
      type: object
      properties:
        idUtilisateur: { type: integer, example: 1 }
        nomUtilisateur: { type: string, example: "Dupont" }
        prenomUtilisateur: { type: string, example: "Alice" }
        login: { type: string, example: "alice.dupont" }
        ville: { type: string, nullable: true }
        codePostal: { type: string, nullable: true }
        dateHeureCreation: { type: string, format: date-time }

    UtilisateurCreation:
      type: object
      required: [nomUtilisateur, prenomUtilisateur, login, motDePasse]
      properties:
        nomUtilisateur: { type: string, maxLength: 50 }
        prenomUtilisateur: { type: string, maxLength: 50 }
        login: { type: string, maxLength: 50 }
        motDePasse: { type: string, minLength: 8 }
        ville: { type: string, nullable: true }
        codePostal: { type: string, maxLength: 5, nullable: true }

    UtilisateurMAJ:
      type: object
      properties:
        nomUtilisateur: { type: string }
        prenomUtilisateur: { type: string }
        ville: { type: string, nullable: true }
        codePostal: { type: string, nullable: true }

    LoginRequest:
      type: object
      required: [login, motDePasse]
      properties:
        login: { type: string, example: "alice.dupont" }
        motDePasse: { type: string, example: "MotDePasse123!" }

    LoginResponse:
      type: object
      properties:
        token: { type: string, example: "eyJhbGci..." }
        utilisateur: { $ref: "#/components/schemas/Utilisateur" }

    Compte:
      type: object
      properties:
        idCompte: { type: integer }
        descriptionCompte: { type: string, example: "Compte courant" }
        nomBanque: { type: string, example: "BNP Paribas" }
        montantInitial: { type: number, format: float }
        dernierMontantCalcule: { type: number, format: float }

    CompteCreation:
      type: object
      required: [descriptionCompte, nomBanque]
      properties:
        descriptionCompte: { type: string, maxLength: 50 }
        nomBanque: { type: string, maxLength: 50 }
        montantInitial: { type: number, format: float, default: 0.00 }

    CompteMAJ:
      type: object
      properties:
        descriptionCompte: { type: string }
        nomBanque: { type: string }

    SoldeResponse:
      type: object
      properties:
        idCompte: { type: integer }
        date: { type: string, format: date }
        solde: { type: number, format: float, example: 2340.50 }

    Mouvement:
      type: object
      properties:
        idMouvement: { type: integer }
        dateMouvement: { type: string, format: date }
        idCompte: { type: integer }
        idTiers: { type: integer, nullable: true }
        idCategorie: { type: integer, nullable: true }
        idSousCategorie: { type: integer, nullable: true }
        montant: { type: number, format: float, example: 45.90 }
        typeMouvement: { type: string, enum: [D, C] }

    MouvementDetail:
      description: "Mouvement enrichi — correspond à la vue V_MOUVEMENT"
      type: object
      properties:
        idMouvement: { type: integer }
        dateMouvement: { type: string, format: date }
        descriptionCompte: { type: string }
        nomTiers: { type: string, nullable: true }
        nomCategorie: { type: string, nullable: true }
        nomSousCategorie: { type: string, nullable: true }
        montant: { type: number, format: float }
        typeMouvement: { type: string, enum: [D, C] }

    MouvementCreation:
      type: object
      required: [montant, typeMouvement]
      properties:
        dateMouvement: { type: string, format: date }
        idTiers: { type: integer, nullable: true }
        idCategorie: { type: integer, nullable: true }
        idSousCategorie: { type: integer, nullable: true }
        montant: { type: number, format: float, minimum: 0.01 }
        typeMouvement: { type: string, enum: [D, C] }

    PageMouvements:
      type: object
      properties:
        data:
          type: array
          items: { $ref: "#/components/schemas/MouvementDetail" }
        meta: { $ref: "#/components/schemas/PaginationMeta" }

    PaginationMeta:
      type: object
      properties:
        page: { type: integer }
        limit: { type: integer }
        total: { type: integer }
        totalPages: { type: integer }

    Virement:
      type: object
      properties:
        idVirement: { type: integer }
        idCompteDebit: { type: integer }
        idCompteCredit: { type: integer }
        montant: { type: number, format: float }
        dateVirement: { type: string, format: date }
        commentaire: { type: string, nullable: true }
        virementInterUtilisateur: { type: boolean }

    VirementCreation:
      type: object
      required: [idCompteDebit, idCompteCredit, montant]
      properties:
        idCompteDebit: { type: integer, example: 1 }
        idCompteCredit: { type: integer, example: 3 }
        montant: { type: number, format: float, minimum: 0.01 }
        dateVirement: { type: string, format: date }
        commentaire: { type: string, nullable: true }
        idCategorie: { type: integer, nullable: true }
        idSousCategorie: { type: integer, nullable: true }

    Categorie:
      type: object
      properties:
        idCategorie: { type: integer }
        nomCategorie: { type: string, example: "Alimentation" }
        idUtilisateur: { type: integer, nullable: true, description: "NULL = catégorie système" }

    CategorieCreation:
      type: object
      required: [nomCategorie]
      properties:
        nomCategorie: { type: string, maxLength: 50 }

    CategorieAvecSousCategories:
      type: object
      properties:
        idCategorie: { type: integer }
        nomCategorie: { type: string }
        idUtilisateur: { type: integer, nullable: true }
        sousCategories:
          type: array
          items: { $ref: "#/components/schemas/SousCategorie" }

    SousCategorie:
      type: object
      properties:
        idSousCategorie: { type: integer }
        nomSousCategorie: { type: string, example: "Courses" }
        idCategorie: { type: integer }
        montant_base: { type: integer, nullable: true }
        periode: { type: string, enum: [M, H, A, Q] }

    SousCategorieCreation:
      type: object
      required: [nomSousCategorie]
      properties:
        nomSousCategorie: { type: string, maxLength: 50 }
        montant_base: { type: integer, nullable: true }
        periode: { type: string, enum: [M, H, A, Q], default: "M" }

    Tiers:
      type: object
      properties:
        idTiers: { type: integer }
        nomTiers: { type: string, example: "Carrefour" }
        idUtilisateur: { type: integer }
        idSousCategorieDefaut: { type: integer, nullable: true }

    TiersCreation:
      type: object
      required: [nomTiers]
      properties:
        nomTiers: { type: string, maxLength: 50 }
        idSousCategorieDefaut: { type: integer, nullable: true }

    PageTiers:
      type: object
      properties:
        data:
          type: array
          items: { $ref: "#/components/schemas/Tiers" }
        meta: { $ref: "#/components/schemas/PaginationMeta" }

    Erreur:
      type: object
      properties:
        code: { type: integer }
        message: { type: string }
        details: { type: string, nullable: true }

  responses:
    BadRequest:
      description: "400 — Requête invalide"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
    Unauthorized:
      description: "401 — Token manquant ou invalide"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
    Forbidden:
      description: "403 — Accès refusé"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
    NotFound:
      description: "404 — Ressource non trouvée"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
    Conflict:
      description: "409 — Ressource déjà existante"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
    UnprocessableEntity:
      description: "422 — Erreur métier (trigger SQL)"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
    InternalError:
      description: "500 — Erreur interne"
      content:
        application/json:
          schema: { $ref: "#/components/schemas/Erreur" }
