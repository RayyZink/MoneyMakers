# ============================================================
# COMPONENTS
# ============================================================

components:

  # ------------------------------------------------------------
  # SECURITY SCHEMES
  # ------------------------------------------------------------

  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: "Token JWT obtenu via POST /auth/login"

  # ------------------------------------------------------------
  # PARAMETERS RÉUTILISABLES
  # ------------------------------------------------------------

  parameters:
    idUtilisateur:
      name: idUtilisateur
      in: path
      required: true
      description: "Identifiant de l'utilisateur"
      schema:
        type: integer
        example: 1

    idCompte:
      name: idCompte
      in: path
      required: true
      description: "Identifiant du compte bancaire"
      schema:
        type: integer
        example: 1

    idMouvement:
      name: idMouvement
      in: path
      required: true
      description: "Identifiant du mouvement"
      schema:
        type: integer
        example: 1

    idVirement:
      name: idVirement
      in: path
      required: true
      description: "Identifiant du virement"
      schema:
        type: integer
        example: 1

    idCategorie:
      name: idCategorie
      in: path
      required: true
      description: "Identifiant de la catégorie"
      schema:
        type: integer
        example: 1

    idSousCategorie:
      name: idSousCategorie
      in: path
      required: true
      description: "Identifiant de la sous-catégorie"
      schema:
        type: integer
        example: 1

    idTiers:
      name: idTiers
      in: path
      required: true
      description: "Identifiant du tiers"
      schema:
        type: integer
        example: 1

    page:
      name: page
      in: query
      required: false
      description: "Numéro de page (commence à 1)"
      schema:
        type: integer
        minimum: 1
        default: 1
        example: 1

    limit:
      name: limit
      in: query
      required: false
      description: "Nombre d'éléments par page"
      schema:
        type: integer
        minimum: 1
        maximum: 100
        default: 20
        example: 20

  # ------------------------------------------------------------
  # SCHEMAS
  # ------------------------------------------------------------

  schemas:

    # -- UTILISATEUR --

    Utilisateur:
      type: object
      properties:
        idUtilisateur:
          type: integer
          example: 1
        nomUtilisateur:
          type: string
          example: "Dupont"
        prenomUtilisateur:
          type: string
          example: "Alice"
        login:
          type: string
          example: "alice.dupont"
        ville:
          type: string
          nullable: true
          example: "Lille"
        codePostal:
          type: string
          nullable: true
          maxLength: 5
          example: "59000"
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-01-15T10:30:00Z"
        dateHeureMAJ:
          type: string
          format: date-time
          example: "2026-06-01T08:00:00Z"

    UtilisateurCreation:
      type: object
      required: [nomUtilisateur, prenomUtilisateur, login, motDePasse]
      properties:
        nomUtilisateur:
          type: string
          maxLength: 50
          example: "Dupont"
        prenomUtilisateur:
          type: string
          maxLength: 50
          example: "Alice"
        login:
          type: string
          maxLength: 50
          example: "alice.dupont"
        motDePasse:
          type: string
          minLength: 8
          example: "MotDePasse123!"
        ville:
          type: string
          maxLength: 50
          nullable: true
          example: "Lille"
        codePostal:
          type: string
          maxLength: 5
          nullable: true
          example: "59000"

    UtilisateurMAJ:
      type: object
      properties:
        nomUtilisateur:
          type: string
          maxLength: 50
          example: "Dupont"
        prenomUtilisateur:
          type: string
          maxLength: 50
          example: "Alice"
        ville:
          type: string
          maxLength: 50
          nullable: true
          example: "Paris"
        codePostal:
          type: string
          maxLength: 5
          nullable: true
          example: "75001"

    # -- AUTH --

    LoginRequest:
      type: object
      required: [login, motDePasse]
      properties:
        login:
          type: string
          example: "alice.dupont"
        motDePasse:
          type: string
          example: "MotDePasse123!"

    LoginResponse:
      type: object
      properties:
        token:
          type: string
          description: "Token JWT à utiliser dans le header Authorization"
          example: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        utilisateur:
          $ref: "#/components/schemas/Utilisateur"

    # -- COMPTE --

    Compte:
      type: object
      properties:
        idCompte:
          type: integer
          example: 1
        descriptionCompte:
          type: string
          example: "Compte courant principal"
        nomBanque:
          type: string
          example: "BNP Paribas"
        idUtilisateur:
          type: integer
          example: 1
        montantInitial:
          type: number
          format: float
          example: 1500.00
        dernierMontantCalcule:
          type: number
          format: float
          example: 2340.50
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-01-15T10:30:00Z"
        dateHeureMAJ:
          type: string
          format: date-time
          example: "2026-06-01T08:00:00Z"

    CompteCreation:
      type: object
      required: [descriptionCompte, nomBanque]
      properties:
        descriptionCompte:
          type: string
          maxLength: 50
          example: "Compte courant principal"
        nomBanque:
          type: string
          maxLength: 50
          example: "BNP Paribas"
        montantInitial:
          type: number
          format: float
          default: 0.00
          example: 1500.00

    CompteMAJ:
      type: object
      properties:
        descriptionCompte:
          type: string
          maxLength: 50
          example: "Compte courant BNP"
        nomBanque:
          type: string
          maxLength: 50
          example: "BNP Paribas"

    SoldeResponse:
      type: object
      properties:
        idCompte:
          type: integer
          example: 1
        date:
          type: string
          format: date
          example: "2026-01-31"
        solde:
          type: number
          format: float
          example: 2340.50

    # -- MOUVEMENT --

    Mouvement:
      type: object
      properties:
        idMouvement:
          type: integer
          example: 42
        dateMouvement:
          type: string
          format: date
          example: "2026-06-05"
        idCompte:
          type: integer
          example: 1
        idTiers:
          type: integer
          nullable: true
          example: 3
        idCategorie:
          type: integer
          nullable: true
          example: 1
        idSousCategorie:
          type: integer
          nullable: true
          example: 2
        idVirement:
          type: integer
          nullable: true
          example: null
        montant:
          type: number
          format: float
          example: 45.90
        typeMouvement:
          type: string
          enum: [D, C]
          example: "D"
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-06-05T14:22:00Z"
        dateHeureMAJ:
          type: string
          format: date-time
          example: "2026-06-05T14:22:00Z"

    MouvementDetail:
      description: "Mouvement enrichi avec les noms (correspond à la vue V_MOUVEMENT)"
      type: object
      properties:
        idMouvement:
          type: integer
          example: 42
        dateMouvement:
          type: string
          format: date
          example: "2026-06-05"
        descriptionCompte:
          type: string
          example: "Compte courant principal"
        nomBanque:
          type: string
          example: "BNP Paribas"
        nomTiers:
          type: string
          nullable: true
          example: "Carrefour City"
        idCategorie:
          type: integer
          nullable: true
          example: 1
        nomCategorie:
          type: string
          nullable: true
          example: "Alimentation"
        idSousCategorie:
          type: integer
          nullable: true
          example: 2
        nomSousCategorie:
          type: string
          nullable: true
          example: "Courses"
        montant:
          type: number
          format: float
          example: 45.90
        typeMouvement:
          type: string
          enum: [D, C]
          example: "D"

    MouvementCreation:
      type: object
      required: [montant, typeMouvement]
      properties:
        dateMouvement:
          type: string
          format: date
          example: "2026-06-05"
        idTiers:
          type: integer
          nullable: true
          example: 3
        idCategorie:
          type: integer
          nullable: true
          example: 1
        idSousCategorie:
          type: integer
          nullable: true
          example: 2
        montant:
          type: number
          format: float
          minimum: 0.01
          example: 45.90
        typeMouvement:
          type: string
          enum: [D, C]
          example: "D"

    MouvementMAJ:
      type: object
      properties:
        dateMouvement:
          type: string
          format: date
          example: "2026-06-05"
        idTiers:
          type: integer
          nullable: true
          example: 3
        idCategorie:
          type: integer
          nullable: true
          example: 1
        idSousCategorie:
          type: integer
          nullable: true
          example: 2
        montant:
          type: number
          format: float
          minimum: 0.01
          example: 45.90
        typeMouvement:
          type: string
          enum: [D, C]
          example: "D"

    # -- VIREMENT --

    Virement:
      type: object
      properties:
        idVirement:
          type: integer
          example: 1
        idCompteDebit:
          type: integer
          example: 1
        idCompteCredit:
          type: integer
          example: 3
        montant:
          type: number
          format: float
          example: 200.00
        dateVirement:
          type: string
          format: date
          example: "2026-06-05"
        commentaire:
          type: string
          nullable: true
          example: "Remboursement dîner"
        idUtilisateurInitiateur:
          type: integer
          example: 1
        virementInterUtilisateur:
          type: boolean
          example: false
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-06-05T14:22:00Z"

    VirementCreation:
      type: object
      required: [idCompteDebit, idCompteCredit, montant]
      properties:
        idCompteDebit:
          type: integer
          example: 1
        idCompteCredit:
          type: integer
          example: 3
        montant:
          type: number
          format: float
          minimum: 0.01
          example: 200.00
        dateVirement:
          type: string
          format: date
          example: "2026-06-05"
        commentaire:
          type: string
          maxLength: 255
          nullable: true
          example: "Remboursement dîner"
        idCategorie:
          type: integer
          nullable: true
          example: 2
        idSousCategorie:
          type: integer
          nullable: true
          example: 5

    # -- CATEGORIE --

    Categorie:
      type: object
      properties:
        idCategorie:
          type: integer
          example: 1
        nomCategorie:
          type: string
          example: "Alimentation"
        idUtilisateur:
          type: integer
          nullable: true
          description: "NULL si catégorie système partagée"
          example: null
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-01-15T10:30:00Z"

    CategorieCreation:
      type: object
      required: [nomCategorie]
      properties:
        nomCategorie:
          type: string
          maxLength: 50
          example: "Santé"

    CategorieAvecSousCategories:
      type: object
      properties:
        idCategorie:
          type: integer
          example: 1
        nomCategorie:
          type: string
          example: "Alimentation"
        idUtilisateur:
          type: integer
          nullable: true
          example: null
        sousCategories:
          type: array
          items:
            $ref: "#/components/schemas/SousCategorie"

    # -- SOUS-CATEGORIE --

    SousCategorie:
      type: object
      properties:
        idSousCategorie:
          type: integer
          example: 2
        nomSousCategorie:
          type: string
          example: "Courses"
        idCategorie:
          type: integer
          example: 1
        montant_base:
          type: integer
          nullable: true
          description: "Budget prévisionnel de base"
          example: 200
        periode:
          type: string
          enum: [M, H, A, Q]
          description: "M=Mensuel, H=Hebdomadaire, A=Aléatoire, Q=Quotidien"
          example: "M"
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-01-15T10:30:00Z"

    SousCategorieCreation:
      type: object
      required: [nomSousCategorie]
      properties:
        nomSousCategorie:
          type: string
          maxLength: 50
          example: "Pharmacie"
        montant_base:
          type: integer
          nullable: true
          example: 50
        periode:
          type: string
          enum: [M, H, A, Q]
          default: "M"
          example: "M"

    # -- TIERS --

    Tiers:
      type: object
      properties:
        idTiers:
          type: integer
          example: 3
        nomTiers:
          type: string
          example: "Carrefour City"
        idUtilisateur:
          type: integer
          example: 1
        idSousCategorieDefaut:
          type: integer
          nullable: true
          example: 2
        dateHeureCreation:
          type: string
          format: date-time
          example: "2026-01-15T10:30:00Z"

    TiersCreation:
      type: object
      required: [nomTiers]
      properties:
        nomTiers:
          type: string
          maxLength: 50
          example: "Carrefour City"
        idSousCategorieDefaut:
          type: integer
          nullable: true
          example: 2

    # -- PAGINATION --

    PageUtilisateurs:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: "#/components/schemas/Utilisateur"
        meta:
          $ref: "#/components/schemas/PaginationMeta"

    PageMouvements:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: "#/components/schemas/MouvementDetail"
        meta:
          $ref: "#/components/schemas/PaginationMeta"

    PageVirements:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: "#/components/schemas/Virement"
        meta:
          $ref: "#/components/schemas/PaginationMeta"

    PageTiers:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: "#/components/schemas/Tiers"
        meta:
          $ref: "#/components/schemas/PaginationMeta"

    PaginationMeta:
      type: object
      properties:
        page:
          type: integer
          example: 1
        limit:
          type: integer
          example: 20
        total:
          type: integer
          example: 87
        totalPages:
          type: integer
          example: 5

    # -- ERREURS --

    Erreur:
      type: object
      properties:
        code:
          type: integer
          example: 404
        message:
          type: string
          example: "Ressource non trouvée"
        details:
          type: string
          nullable: true
          example: "Aucun compte trouvé avec l'ID 99"

  # ------------------------------------------------------------
  # RESPONSES RÉUTILISABLES
  # ------------------------------------------------------------

  responses:
    BadRequest:
      description: "Requête invalide — paramètres manquants ou malformés"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 400
            message: "Requête invalide"
            details: "Le champ 'montant' est obligatoire"

    Unauthorized:
      description: "Non authentifié — token JWT manquant ou invalide"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 401
            message: "Non authentifié"
            details: "Token JWT manquant ou expiré"

    Forbidden:
      description: "Accès refusé — vous n'avez pas les droits sur cette ressource"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 403
            message: "Accès refusé"
            details: "Cette ressource ne vous appartient pas"

    NotFound:
      description: "Ressource non trouvée"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 404
            message: "Ressource non trouvée"
            details: "Aucun compte trouvé avec l'ID 99"

    Conflict:
      description: "Conflit — la ressource existe déjà"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 409
            message: "Conflit"
            details: "Un utilisateur avec ce login existe déjà"

    UnprocessableEntity:
      description: "Entité non traitable — erreur métier (ex: trigger de sécurité SQL)"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 422
            message: "Erreur métier"
            details: "La sous-catégorie n'appartient pas à la catégorie indiquée"

    InternalError:
      description: "Erreur interne du serveur"
      content:
        application/json:
          schema:
            $ref: "#/components/schemas/Erreur"
          example:
            code: 500
            message: "Erreur interne"
            details: "Une erreur inattendue s'est produite"
